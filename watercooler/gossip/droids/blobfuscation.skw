gen(){
  model_call "NO_WORDS:cl+ean,cl+ear,pu+re ALT:precise,direct,minimal,cls,strict NO_CHAR:[\\u2014]" |
  tr -d '\000-\010\013\014\016-\037'
}

ok=0
