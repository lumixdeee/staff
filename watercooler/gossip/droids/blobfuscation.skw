ᚕ=cntr:I,A,!D
A='[:alnum:]_=|><(){}[]\n'
R='(?i)(c[^ ]*l[^ ]*e[^ ]*a[^ ]*|clar[^ ]*|pur[^ ]*)'
g(){ model_call "$1"|tr -d '\342\200[\220-\225]'; }
b=""
for i in {1..16};do
 t="$(g "NO_WORDS:pur,clar,clea FORMAT:plain_sentences MAX_SENT_LEN:18 NO_EMOJI:1 ALT:precise,plain SEED=$i")"
 grep -Piq "$R"<<<"$t"&&t=""
 [ "$t" ]&&t="$(tr -cd "$A"<<<"$t")"
 grep -Piq "$R"<<<"$t"&&t=""
 [ "$t" ]&&{ [ -z "$b" ]||[ ${#t} -lt ${#b} ]&&b="$t"; }
done
b="$(tr -cd "$A"<<<"$b")"
printf "%s\n%s" "[⨂SPꜲSTՃct𐋊unꛡroʁes𐋋reϴerꚹee𐊷c𖬯an𐌙ea𖩀co𖼜in❤dr𖼽ag𐌈onᏁly𐊸oo𐊬ou🯰ntꚨaiꜶloЯorᚕskwⵃif⅟itⵠdi]
