  𐊬t="$(gen)"
  echo "$𐊬t" | grep -Eiq '(c+l+e+a+n|c+l+e+a+r|p+u+r+e)\w*|[\u2010\u2013\u2014]' && c𐌈t𖼜ue
  pr𖼜tf "%s" "$𐊬t"
  ok=1
  br𐌙k
d𐌈e

